# ============================================
# GRACE-X Brain API Configuration Template
# ============================================
# Copy this file to .env and fill in your API keys
# ============================================

# ============================================
# PROVIDER SELECTION
# ============================================
# Choose your LLM provider: openai, anthropic, openrouter, ollama
LLM_PROVIDER=openrouter

# ============================================
# API KEYS - AI/LLM
# ============================================
# Generic API_KEY (used if provider-specific key not set)
API_KEY=your_generic_api_key_here

# Provider-specific keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENROUTER_API_KEY=your-openrouter-key-here

# ============================================
# SECURITY (REQUIRED FOR PRODUCTION)
# ============================================
# JWT Secret for authenticating users
# Generate a secure string (e.g., using: require('crypto').randomBytes(64).toString('hex'))
JWT_SECRET=your_super_secret_jwt_string_change_this_in_production

# ============================================
# SERVER SETTINGS
# ============================================
PORT=3000
NODE_ENV=development
# NODE_ENV=production

# Request limits
MAX_BODY_SIZE=1mb
REQUEST_TIMEOUT=30000

# ============================================
# LOGGING
# ============================================
ENABLE_LOGGING=true
# Levels: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# SPORTS API CONFIG (Optional)
# ============================================
FOOTBALL_PROVIDER=thesportsdb
BASKETBALL_PROVIDER=balldontlie
TENNIS_PROVIDER=rapidapi
CRICKET_PROVIDER=cricapi
BASEBALL_PROVIDER=mlb-official
RACING_PROVIDER=theracingapi
NFL_PROVIDER=espn-unofficial
F1_PROVIDER=ergast
GOLF_PROVIDER=rapidapi
MMA_PROVIDER=rapidapi
ODDS_PROVIDER=theoddsapi
