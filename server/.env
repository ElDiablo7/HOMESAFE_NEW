# Fully local. No cloud. No external LLM APIs.

LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Commented out - not used when LLM_PROVIDER=ollama:
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=


# ===== Football provider =====
# Options: thesportsdb | apifootball | footballdata
FOOTBALL_PROVIDER=thesportsdb

# API-FOOTBALL / API-SPORTS key (only if FOOTBALL_PROVIDER=apifootball)
API_FOOTBALL_KEY=b7dd48542d7eab24e8b0c1e0fb54c7ba

# football-data.org token (only if FOOTBALL_PROVIDER=footballdata)
FOOTBALL_DATA_TOKEN=put_football_data_org_token_here

# TheSportsDB key (only if FOOTBALL_PROVIDER=thesportsdb)
# Dev keys commonly used are "1" or "3" depending on guidance.
THESPORTSDB_KEY=3

# --- SERVER SETTINGS ---
PORT=3000
REQUEST_TIMEOUT=120000

# --- RACING API ---
RACING_USERNAME=vbpgLg668eirKd6C6cLVzuPg
RACING_PASSWORD=1fCjR7j78E2gQnd6Ca7R5HWz
RACING_PROVIDER=theracingapi
USE_MOCK_DATA=false

# --- WEATHER & NEWS ---
OPENWEATHER_API_KEY=
NEWS_API_KEY=

# --- AUTH ---
